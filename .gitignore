# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# OS / editor noise
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Runtime outputs and generated artifacts
output/
*.csv
*.log
*.pkl
*.tif

# Large constellation files; download or provide locally when using TLE backend
*.bsp

# Local scratch / secrets
.env
.env.*
*.local

# Keep dependency manifests
!requirements.txt

# Keep small checked-in demand samples
!data/
!data/demand/
!data/demand/sample_population_points.csv
!data/demand/global_population_2025_5deg.csv

# Keep compact breach-ratio chart summaries, not multi-GB simulator logs
!breach_ratio/
!breach_ratio/*/
!breach_ratio/*/chart/
!breach_ratio/*/chart/*.csv
breach_ratio/*/logs/

# Local plotting cache
.matplotlib-cache/

# Multi-GB simulator run logs generated by breach-ratio sweeps
experiments/breach_ratio/**/runs/

# Local ad-hoc breach-ratio sweep output not part of the curated summaries
experiments/breach_ratio/starlink_breach_ratio_cpu50_10_20_30gb/
experiments/breach_ratio/starlink_breach_ratio_cpu50_10_20_30gb_config.json

# Experiment raw outputs stay local; commit only figures and config files.
experiments/**/*.csv
experiments/**/*.jsonl
experiments/**/*.json
!experiments/**/run_config.json
!experiments/**/*_config.json
